@using Microsoft.AspNetCore.Components.Web.Virtualization
<h1>Virtualization Provide Items for Paritial updates</h1>

<div id="scroll-container" style="height: 300px; overflow-y: auto; border: 1px solid black;">
    <Virtualize ItemsProvider="@GetItemsAsync" ItemSize="50" Context="item">
        <ItemContent>
            <div class="item"
                 style="border: 1px solid gray; padding: 5px; min-height: 50px;">
                <div>Item @item.Index</div>
            </div>
        </ItemContent>
        <Placeholder>
            <div class="loading-placeholder"
                 style="border: 1px dashed orange; padding: 5px; min-height: 50px; background: #fff8e6;">
                <span>Loading...</span>
            </div>
        </Placeholder>
    </Virtualize>
</div>
@code {
    private List<DynamicItem> items = new();
    private Dictionary<int, DynamicItem> cache = new();

    protected override void OnInitialized()
    {
        items = Enumerable.Range(0, 1000)
            .Select(i => new DynamicItem { Index = i })
            .ToList();
    }

    private async ValueTask<ItemsProviderResult<DynamicItem>> GetItemsAsync(ItemsProviderRequest request)
    {
        var cachedItems = GetCachedItems(request.StartIndex, request.Count);
        if (cachedItems.Any())
        {
            request.ProvideItems(cachedItems, items.Count);
        }
        if (cachedItems.Count < request.Count)
        {
            int remainingStart = request.StartIndex + cachedItems.Count;
            int remainingCount = request.Count - cachedItems.Count;
            if (cachedItems.Any())
            {
                await Task.Delay(2000);
            }
            var remainingItems = items.Skip(remainingStart).Take(remainingCount)
                .Select(i => new DynamicItem { Index = i.Index }).ToList();
            request.ProvideItems(remainingItems, items.Count);
            foreach (var item in remainingItems)
            {
                cache[item.Index] = item;
            }
        }
        return new ItemsProviderResult<DynamicItem>();
    }

    private List<DynamicItem> GetCachedItems(int start, int count)
    {
        var result = new List<DynamicItem>();
        for (int i = start; i < start + count; i++)
        {
            if (cache.TryGetValue(i, out var item))
            {
                result.Add(item);
            }
            else
            {
                break;
            }
        }
        return result;
    }

    public class DynamicItem
    {
        public int Index { get; set; }
    }
}
